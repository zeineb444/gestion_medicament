<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0"
            prefWidth="1500.0"
            style="-fx-background-color:#f5ede4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MainController">

    <!-- SIDEBAR ADMIN -->
    <VBox fx:id="sidebar"
          layoutX="0"
          layoutY="0"
          prefWidth="250.0"
          minWidth="250.0"
          maxWidth="250.0"
          spacing="18"
          style="-fx-background-color:#3b1f0e;"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <padding>
            <Insets top="20" left="20" right="20"/>
        </padding>

        <!-- LOGO -->
        <HBox spacing="15">
            <Button text="☰"
                    onAction="#toggleSidebar"
                    prefWidth="48"
                    prefHeight="48"
                    style="-fx-background-color:#6b3e1f;
                           -fx-text-fill:white;
                           -fx-font-size:22;
                           -fx-background-radius:12;" />

            <Label fx:id="logoLabel"
                   text="🏥 HospitaLink"
                   style="-fx-text-fill:#f5ede4;
                          -fx-font-size:22;
                          -fx-font-weight:bold;" />
        </HBox>

        <Label text="" prefHeight="35"/>

        <Label fx:id="navigationLabel"
               text="NAVIGATION"
               style="-fx-text-fill:#c49a6c;
                      -fx-font-size:14;
                      -fx-font-weight:bold;" />

        <!-- DASHBOARD -->
        <Button fx:id="dashboardBtn"
                text="📊 Dashboard"
                onAction="#showDashboard"
                prefWidth="200"
                prefHeight="42"
                style="-fx-background-color:#c49a6c;
                       -fx-text-fill:white;
                       -fx-background-radius:10;
                       -fx-font-size:15;
                       -fx-font-weight:bold;
                       -fx-alignment:center-left;
                       -fx-padding:0 0 0 18;" />

        <!-- MÉDICAMENTS -->
        <Button fx:id="medicamentBtn"
                text="💊 Médicaments"
                onAction="#showMedicaments"
                prefWidth="200"
                prefHeight="42"
                style="-fx-background-color:transparent;
                       -fx-text-fill:white;
                       -fx-font-size:15;
                       -fx-font-weight:bold;
                       -fx-alignment:center-left;
                       -fx-padding:0 0 0 18;" />

        <!-- NOTIFICATIONS -->
        <Button fx:id="emailBtn"
                text="🔔 Notifications"
                onAction="#showEmails"
                prefWidth="200"
                prefHeight="42"
                style="-fx-background-color:transparent;
                       -fx-text-fill:white;
                       -fx-font-size:15;
                       -fx-font-weight:bold;
                       -fx-alignment:center-left;
                       -fx-padding:0 0 0 18;" />

    </VBox>

    <!-- CONTENU PRINCIPAL -->
    <ScrollPane fx:id="mainScrollPane"
                layoutX="250.0"
                layoutY="0"
                prefWidth="1250.0"
                fitToWidth="true"
                pannable="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                style="-fx-background:#f5ede4;
                       -fx-background-color:#f5ede4;"
                AnchorPane.topAnchor="0.0"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="250.0"
                AnchorPane.rightAnchor="0.0">

        <content>
            <AnchorPane fx:id="contentPane"
                        prefHeight="900.0"
                        prefWidth="1250.0"
                        style="-fx-background-color:#f5ede4;" />
        </content>

    </ScrollPane>

</AnchorPane>