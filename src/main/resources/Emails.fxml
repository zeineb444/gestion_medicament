<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="1800.0"
            prefWidth="1250.0"
            style="-fx-background-color:#f5ede4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.NotificationsController">

    <Label layoutX="60"
           layoutY="45"
           text="🔔 Notifications"
           style="-fx-font-size:34; -fx-font-weight:bold; -fx-text-fill:#7a5535;" />

    <!-- CARTES STATISTIQUES -->
    <HBox layoutX="60" layoutY="120" spacing="20">

        <VBox prefWidth="250" prefHeight="130"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:15; -fx-border-color:#d4b99a; -fx-border-radius:15; -fx-padding:20;">
            <Label text="TOTAL NOTIFICATIONS"
                   style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#7a6150;" />
            <Label fx:id="totalNotificationsLabel"
                   text="0"
                   style="-fx-font-size:36; -fx-font-weight:bold; -fx-text-fill:#7a5535;" />
            <Label text="alertes générées"
                   style="-fx-font-size:14; -fx-text-fill:#7a6150;" />
        </VBox>

        <VBox prefWidth="250" prefHeight="130"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:15; -fx-border-color:#d4b99a; -fx-border-radius:15; -fx-padding:20;">
            <Label text="STOCK FAIBLE"
                   style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#7a6150;" />
            <Label fx:id="stockFaibleLabel"
                   text="0"
                   style="-fx-font-size:36; -fx-font-weight:bold; -fx-text-fill:#c07820;" />
            <Label text="avertissements"
                   style="-fx-font-size:14; -fx-text-fill:#7a6150;" />
        </VBox>

        <VBox prefWidth="250" prefHeight="130"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:15; -fx-border-color:#d4b99a; -fx-border-radius:15; -fx-padding:20;">
            <Label text="RUPTURES"
                   style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#7a6150;" />
            <Label fx:id="ruptureLabel"
                   text="0"
                   style="-fx-font-size:36; -fx-font-weight:bold; -fx-text-fill:#c0392b;" />
            <Label text="critiques"
                   style="-fx-font-size:14; -fx-text-fill:#7a6150;" />
        </VBox>

        <VBox prefWidth="250" prefHeight="130"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:15; -fx-border-color:#d4b99a; -fx-border-radius:15; -fx-padding:20;">
            <Label text="EXPIRATIONS"
                   style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#7a6150;" />
            <Label fx:id="expirationLabel"
                   text="0"
                   style="-fx-font-size:36; -fx-font-weight:bold; -fx-text-fill:#d35400;" />
            <Label text="dates proches"
                   style="-fx-font-size:14; -fx-text-fill:#7a6150;" />
        </VBox>

    </HBox>

    <!-- LISTE NOTIFICATIONS : pas de ScrollPane interne -->
    <VBox fx:id="notificationsBox"
          layoutX="60"
          layoutY="300"
          prefWidth="1120"
          spacing="16"
          style="-fx-background-color:transparent;" />

</AnchorPane>