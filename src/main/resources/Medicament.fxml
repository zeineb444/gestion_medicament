<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="1380.0"
            prefWidth="1250.0"
            style="-fx-background-color:#f5ede4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MedicamentController">

    <Label layoutX="45" layoutY="20"
           text="💊 Gestion des Médicaments"
           style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

    <!-- STATISTIQUES -->
    <Pane layoutX="35" layoutY="80" prefWidth="1180" prefHeight="420"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="25" text="📊 Statistiques du Stock"
               style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <Separator layoutX="25" layoutY="62" prefWidth="1130"/>

        <HBox layoutX="25" layoutY="85" spacing="18">
            <VBox prefWidth="250" prefHeight="90" alignment="CENTER"
                  style="-fx-background-color:#f5ede4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
                <Label fx:id="totalMedLabel" text="0"
                       style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#7A5535;"/>
                <Label text="Total"/>
            </VBox>

            <VBox prefWidth="250" prefHeight="90" alignment="CENTER"
                  style="-fx-background-color:#f5ede4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
                <Label fx:id="okMedLabel" text="0"
                       style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#1B7F35;"/>
                <Label text="Suffisant"/>
            </VBox>

            <VBox prefWidth="250" prefHeight="90" alignment="CENTER"
                  style="-fx-background-color:#f5ede4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
                <Label fx:id="faibleMedLabel" text="0"
                       style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#C0392B;"/>
                <Label text="Faible"/>
            </VBox>

            <VBox prefWidth="250" prefHeight="90" alignment="CENTER"
                  style="-fx-background-color:#f5ede4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
                <Label fx:id="expirationMedLabel" text="0"
                       style="-fx-font-size:30; -fx-font-weight:bold; -fx-text-fill:#D35400;"/>
                <Label text="Expirés bientôt"/>
            </VBox>
        </HBox>

        <!-- BARRES DE STOCK AVEC SCROLL -->
        <ScrollPane layoutX="25"
                    layoutY="195"
                    prefWidth="1130"
                    prefHeight="150"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background:transparent; -fx-background-color:transparent;">

            <content>
                <VBox fx:id="stockBarsBox"
                      prefWidth="1110"
                      spacing="12"
                      style="-fx-background-color:transparent;"/>
            </content>
        </ScrollPane>

        <HBox layoutX="25" layoutY="365" spacing="20">
            <Button text="🔴 Bientôt expirés"
                    onAction="#filtrerExpiration"
                    prefWidth="170" prefHeight="40"
                    style="-fx-background-color:#F8D7DA; -fx-text-fill:#8B1E1E; -fx-background-radius:22; -fx-font-weight:bold;"/>

            <Button text="Tout afficher"
                    onAction="#afficherTousMedicaments"
                    prefWidth="150" prefHeight="40"
                    style="-fx-background-color:#E8D5B8; -fx-text-fill:#7A5535; -fx-background-radius:22; -fx-font-weight:bold;"/>
        </HBox>
    </Pane>

    <!-- RECHERCHE -->
    <Pane layoutX="35" layoutY="530" prefWidth="570" prefHeight="390"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="25" text="🔍 Recherche"
               style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />
        <Separator layoutX="25" layoutY="62" prefWidth="520"/>

        <Label layoutX="25" layoutY="90" text="Nom du médicament"/>
        <TextField fx:id="rechercheNomField" layoutX="25" layoutY="115" prefWidth="520" prefHeight="38"
                   promptText="Ex: Paracetamol..."
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="25" layoutY="165" text="Catégorie"/>
        <ComboBox fx:id="rechercheCategorieField" layoutX="25" layoutY="190" prefWidth="520" prefHeight="38"
                  promptText="Toutes catégories"
                  style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="25" layoutY="240" text="Service"/>
        <ComboBox fx:id="rechercheServiceField" layoutX="25" layoutY="265" prefWidth="520" prefHeight="38"
                  promptText="Tous les services"
                  style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Button layoutX="25" layoutY="325" text="🔍 Rechercher" onAction="#rechercherMedicaments"
                prefWidth="150" prefHeight="38"
                style="-fx-background-color:#A07850; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold;"/>

        <Button layoutX="205" layoutY="325" text="Effacer" onAction="#afficherTousMedicaments"
                prefWidth="120" prefHeight="38"
                style="-fx-background-color:#E8D5B8; -fx-text-fill:#7A5535; -fx-background-radius:20; -fx-font-weight:bold;"/>
    </Pane>

    <!-- FORMULAIRE -->
    <Pane layoutX="635" layoutY="530" prefWidth="580" prefHeight="460"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="25" text="📋 Informations Médicament"
               style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />
        <Separator layoutX="25" layoutY="62" prefWidth="530"/>

        <Label layoutX="25" layoutY="85" text="Nom *"/>
        <TextField fx:id="nomField" layoutX="25" layoutY="108" prefWidth="260" prefHeight="35"
                   promptText="Nom du médicament"
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="310" layoutY="85" text="Stock"/>
        <TextField fx:id="stockField" layoutX="310" layoutY="108" prefWidth="240" prefHeight="35"
                   promptText="0"
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="25" layoutY="145" text="Catégorie"/>
        <ComboBox fx:id="categorieField" layoutX="25" layoutY="168" prefWidth="260" prefHeight="35"
                  promptText="--"
                  style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="310" layoutY="145" text="Seuil min."/>
        <TextField fx:id="seuilField" layoutX="310" layoutY="168" prefWidth="240" prefHeight="35"
                   promptText="0"
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="25" layoutY="205" text="Dosage"/>
        <TextField fx:id="dosageField" layoutX="25" layoutY="228" prefWidth="260" prefHeight="35"
                   promptText="500mg"
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="310" layoutY="205" text="Forme"/>
        <TextField fx:id="formeField" layoutX="310" layoutY="228" prefWidth="240" prefHeight="35"
                   promptText="Comprimé..."
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="25" layoutY="265" text="Service"/>
        <TextField fx:id="serviceField" layoutX="25" layoutY="288" prefWidth="260" prefHeight="35"
                   promptText="Urgence..."
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <Label layoutX="310" layoutY="265" text="Expiration"/>
        <TextField fx:id="dateField" layoutX="310" layoutY="288" prefWidth="240" prefHeight="35"
                   promptText="yyyy-mm-dd"
                   style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#D9B99A;"/>

        <HBox layoutX="25" layoutY="365" spacing="12">
            <Button text="➕ Ajouter" onAction="#ajouterMedicament" prefWidth="120" prefHeight="38"
                    style="-fx-background-color:#A07850; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold;"/>
            <Button text="➞ Modifier" onAction="#modifierMedicament" prefWidth="120" prefHeight="38"
                    style="-fx-background-color:#8B633F; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold;"/>
            <Button text="🗑 Supprimer" onAction="#supprimerMedicament" prefWidth="130" prefHeight="38"
                    style="-fx-background-color:#6B3E1F; -fx-text-fill:white; -fx-background-radius:20; -fx-font-weight:bold;"/>
            <Button text="↻ Reset" onAction="#resetForm" prefWidth="100" prefHeight="38"
                    style="-fx-background-color:#E8D5B8; -fx-text-fill:#7A5535; -fx-background-radius:20; -fx-font-weight:bold;"/>
        </HBox>

        <TextField fx:id="descriptionField" visible="false" managed="false" text=""/>
        <TextField fx:id="lotField" visible="false" managed="false" text="LOT001"/>
        <TextField fx:id="quantiteLotField" visible="false" managed="false" text="0"/>
    </Pane>

    <!-- TABLEAU -->
    <Pane layoutX="35" layoutY="1020" prefWidth="1180" prefHeight="330"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="25" text="☰ Liste des Médicaments"
               style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <TableView fx:id="medicamentTable"
                   layoutX="25" layoutY="75"
                   prefWidth="1125" prefHeight="220"
                   style="-fx-background-color:#fffaf5; -fx-control-inner-background:#fffaf5; -fx-table-cell-border-color:#E8D8C8; -fx-border-color:transparent;">
            <columns>
                <TableColumn fx:id="nomColumn" text="Nom"/>
                <TableColumn fx:id="categorieColumn" text="Catégorie"/>
                <TableColumn fx:id="dosageColumn" text="Dosage"/>
                <TableColumn fx:id="formeColumn" text="Forme"/>
                <TableColumn fx:id="stockColumn" text="Stock"/>
                <TableColumn fx:id="seuilColumn" text="Seuil"/>
                <TableColumn fx:id="expirationColumn" text="Expiration"/>
                <TableColumn fx:id="serviceColumn" text="Service"/>
                <TableColumn fx:id="etatColumn" text="État"/>
            </columns>
        </TableView>
    </Pane>

</AnchorPane>