<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="650.0"
            prefWidth="950.0"
            style="-fx-background-color: linear-gradient(to bottom right, #FFF3E0, #FFF8E1, #E3F2FD);"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.SuiviMedicalController">

    <children>

        <Circle layoutX="70" layoutY="70" radius="45" fill="#FFD6A5" opacity="0.45"/>
        <Circle layoutX="890" layoutY="90" radius="60" fill="#BBDEFB" opacity="0.35"/>

        <Label layoutX="310.0"
               layoutY="25.0"
               text="🩺 Gestion du Suivi Médical"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6D4C41;" />

        <Pane layoutX="50.0"
              layoutY="90.0"
              prefHeight="250.0"
              prefWidth="850.0"
              style="-fx-background-color: rgba(255,255,255,0.92);
                     -fx-background-radius: 24;
                     -fx-border-radius: 24;
                     -fx-border-color: #FFD6A5;
                     -fx-border-width: 2;">

            <children>

                <Label layoutX="35.0"
                       layoutY="22.0"
                       text="Informations suivi médical"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6D4C41;" />

                <Label layoutX="50.0" layoutY="70.0" text="ID Médicament :" />
                <TextField fx:id="medicamentIdField"
                           layoutX="180.0"
                           layoutY="63.0"
                           prefWidth="230.0"
                           promptText="ID médicament" />

                <Label layoutX="50.0" layoutY="120.0" text="Nom Patient :" />
                <TextField fx:id="nomPatientField"
                           layoutX="180.0"
                           layoutY="113.0"
                           prefWidth="230.0"
                           promptText="Nom patient" />

                <Label layoutX="50.0" layoutY="170.0" text="Date Suivi :" />
                <TextField fx:id="dateSuiviField"
                           layoutX="180.0"
                           layoutY="163.0"
                           prefWidth="230.0"
                           promptText="yyyy-mm-dd" />

                <Label layoutX="470.0" layoutY="70.0" text="Observation :" />
                <TextField fx:id="observationField"
                           layoutX="590.0"
                           layoutY="63.0"
                           prefWidth="230.0"
                           promptText="Observation" />

                <Label layoutX="470.0" layoutY="120.0" text="État Patient :" />
                <TextField fx:id="etatPatientField"
                           layoutX="590.0"
                           layoutY="113.0"
                           prefWidth="230.0"
                           promptText="AMELIORATION / STABLE / CRITIQUE" />

                <Button fx:id="ajouterBtn"
                        layoutX="115.0"
                        layoutY="205.0"
                        prefWidth="120.0"
                        text="➕ Ajouter"
                        onAction="#ajouterSuivi"
                        style="-fx-background-color: #42A5F5;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;" />

                <Button fx:id="modifierBtn"
                        layoutX="275.0"
                        layoutY="205.0"
                        prefWidth="120.0"
                        text="✏️ Modifier"
                        onAction="#modifierSuivi"
                        style="-fx-background-color: #66BB6A;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;" />

                <Button fx:id="supprimerBtn"
                        layoutX="435.0"
                        layoutY="205.0"
                        prefWidth="120.0"
                        text="🗑️ Supprimer"
                        onAction="#supprimerSuivi"
                        style="-fx-background-color: #EF5350;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;" />

                <Button fx:id="resetBtn"
                        layoutX="595.0"
                        layoutY="205.0"
                        prefWidth="120.0"
                        text="🔄 Reset"
                        onAction="#resetForm"
                        style="-fx-background-color: #AB47BC;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;" />

            </children>
        </Pane>

        <Pane layoutX="50.0"
              layoutY="370.0"
              prefHeight="230.0"
              prefWidth="850.0"
              style="-fx-background-color: rgba(255,255,255,0.92);
                     -fx-background-radius: 24;
                     -fx-border-radius: 24;
                     -fx-border-color: #BBDEFB;
                     -fx-border-width: 2;">

            <children>

                <Label layoutX="35.0"
                       layoutY="15.0"
                       text="Liste des suivis médicaux"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #6D4C41;" />

                <TableView fx:id="suiviTable"
                           layoutX="20.0"
                           layoutY="55.0"
                           prefHeight="150.0"
                           prefWidth="810.0">

                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                        <TableColumn fx:id="medicamentIdColumn" text="ID Médicament" prefWidth="120.0" />
                        <TableColumn fx:id="nomPatientColumn" text="Nom Patient" prefWidth="160.0" />
                        <TableColumn fx:id="dateSuiviColumn" text="Date Suivi" prefWidth="120.0" />
                        <TableColumn fx:id="observationColumn" text="Observation" prefWidth="220.0" />
                        <TableColumn fx:id="etatPatientColumn" text="État Patient" prefWidth="140.0" />
                    </columns>

                </TableView>

            </children>
        </Pane>

    </children>
</AnchorPane>