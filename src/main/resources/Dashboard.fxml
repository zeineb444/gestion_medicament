<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>

<AnchorPane prefHeight="920.0"
            prefWidth="1180.0"
            style="-fx-background-color:#f5ede4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.DashboardController">

    <!-- TITRE -->
    <Label layoutX="40" layoutY="35"
           text="📊 Dashboard Hospitalier"
           style="-fx-font-size:34; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

    <!-- VUE D'ENSEMBLE -->
    <Pane layoutX="25" layoutY="120" prefWidth="1120" prefHeight="210"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="20"
               text="VUE D'ENSEMBLE"
               style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <VBox layoutX="25" layoutY="65" prefWidth="250" prefHeight="120" spacing="6" alignment="CENTER"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
            <Label text="TOTAL MÉDICAMENTS"
                   style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#8B5E3C;" />
            <Label fx:id="totalMedicamentsLabel"
                   text="0"
                   style="-fx-font-size:38; -fx-font-weight:bold; -fx-text-fill:#8B5E3C;" />
            <Label text="références actives"
                   style="-fx-font-size:13; -fx-text-fill:#8B5E3C;" />
        </VBox>

        <VBox layoutX="295" layoutY="65" prefWidth="250" prefHeight="120" spacing="6" alignment="CENTER"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
            <Label text="STOCK TOTAL"
                   style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#8B5E3C;" />
            <Label fx:id="stockTotalLabel"
                   text="0"
                   style="-fx-font-size:38; -fx-font-weight:bold; -fx-text-fill:#2E7D32;" />
            <Label text="unités disponibles"
                   style="-fx-font-size:13; -fx-text-fill:#8B5E3C;" />
        </VBox>

        <VBox layoutX="565" layoutY="65" prefWidth="250" prefHeight="120" spacing="6" alignment="CENTER"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
            <Label text="STOCK FAIBLE"
                   style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#8B5E3C;" />
            <Label fx:id="stockFaibleLabel"
                   text="0"
                   style="-fx-font-size:38; -fx-font-weight:bold; -fx-text-fill:#C0392B;" />
            <Label text="sous le seuil minimum"
                   style="-fx-font-size:13; -fx-text-fill:#8B5E3C;" />
        </VBox>

        <VBox layoutX="835" layoutY="65" prefWidth="250" prefHeight="120" spacing="6" alignment="CENTER"
              style="-fx-background-color:#fdf8f4; -fx-background-radius:14; -fx-border-color:#D9B99A; -fx-border-radius:14;">
            <Label text="PATIENTS SUIVIS"
                   style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#8B5E3C;" />
            <Label fx:id="patientsSuivisLabel"
                   text="0"
                   style="-fx-font-size:38; -fx-font-weight:bold; -fx-text-fill:#1565C0;" />
            <Label text="suivis enregistrés"
                   style="-fx-font-size:13; -fx-text-fill:#8B5E3C;" />
        </VBox>

    </Pane>

    <!-- GRAPHIQUES -->
    <Label layoutX="25" layoutY="355"
           text="GRAPHIQUES"
           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

    <!-- ÉVOLUTION DU STOCK -->
    <Pane layoutX="25" layoutY="390" prefWidth="545" prefHeight="280"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="22"
               text="📈 ÉVOLUTION DU STOCK"
               style="-fx-font-size:17; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <BarChart fx:id="stockBarChart"
                  layoutX="20"
                  layoutY="55"
                  prefWidth="505"
                  prefHeight="205"
                  legendVisible="true"
                  animated="false">
            <xAxis>
                <CategoryAxis side="BOTTOM"/>
            </xAxis>
            <yAxis>
                <NumberAxis side="LEFT"/>
            </yAxis>
        </BarChart>
    </Pane>

    <!-- PAR CATÉGORIE -->
    <Pane layoutX="595" layoutY="390" prefWidth="550" prefHeight="280"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="22"
               text="◔ PAR CATÉGORIE"
               style="-fx-font-size:17; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <PieChart fx:id="categoriePieChart"
                  layoutX="45"
                  layoutY="50"
                  prefWidth="460"
                  prefHeight="210"
                  legendVisible="true"
                  animated="false"/>
    </Pane>

    <!-- RÉFÉRENCES -->
    <Label layoutX="25" layoutY="695"
           text="RÉFÉRENCES"
           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

    <!-- MÉDICAMENTS PAR SERVICE -->
    <Pane layoutX="25" layoutY="720" prefWidth="545" prefHeight="180"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="22"
               text="🏥 MÉDICAMENTS PAR SERVICE"
               style="-fx-font-size:17; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <VBox fx:id="medicamentsParServiceBox"
              layoutX="30"
              layoutY="65"
              prefWidth="485"
              prefHeight="95"
              spacing="0"/>
    </Pane>

    <!-- TOP MÉDICAMENTS -->
    <Pane layoutX="595" layoutY="720" prefWidth="550" prefHeight="180"
          style="-fx-background-color:#fffaf5; -fx-background-radius:18; -fx-border-color:#D9B99A; -fx-border-radius:18;">

        <Label layoutX="25" layoutY="22"
               text="🏆 TOP MÉDICAMENTS UTILISÉS"
               style="-fx-font-size:17; -fx-font-weight:bold; -fx-text-fill:#7A5535;" />

        <VBox fx:id="topMedicamentsBox"
              layoutX="30"
              layoutY="65"
              prefWidth="490"
              prefHeight="95"
              spacing="0"/>
    </Pane>

</AnchorPane>